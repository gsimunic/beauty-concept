generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ExpenseCategory {
  RENT
  SALARY
  MARKETING
  SUPPLIES
  OTHER
}

enum StockMovementType {
  PURCHASE
  SALE
  CONSUMPTION
  MANUAL_ADJUSTMENT
}

enum ClientPackageStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum SaleItemType {
  PRODUCT
  SERVICE
  PACKAGE
}

enum StaffType {
  INTERNAL
  EXTERNAL
}

model User {
  id                   String        @id @default(uuid())
  name                 String?
  email                String        @unique
  role                 Role          @default(EMPLOYEE)
  language             String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  employeeAppointments Appointment[] @relation("EmployeeAppointments")
}

model Employee {
  id                   String               @id @default(cuid())
  name                 String
  email                String?              @unique
  active               Boolean              @default(true)
  baseSalary           Decimal?             @db.Decimal(10, 2)
  commissionPercentage Decimal?             @db.Decimal(5, 2)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  serviceMappings      ServiceEmployee[]

  @@index([name])
  @@index([active])
}

model Staff {
  id                    String              @id @default(cuid())
  name                  String
  type                  StaffType
  active                Boolean             @default(true)
  baseSalary            Decimal?            @db.Decimal(10, 2)
  commissionPercentage  Decimal?            @db.Decimal(5, 2)
  profitSharePercentage Decimal?            @db.Decimal(5, 2)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  sales                 Sale[]
  packageUsages         ClientPackageUsage[]

  @@index([name])
  @@index([type])
  @@index([active])
}

model Client {
  id             String          @id @default(cuid())
  name           String
  phone          String
  email          String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]
  clientPackages ClientPackage[]

  @@index([name])
  @@index([phone])
  @@index([createdAt])
}

model Service {
  id                 String                @id @default(cuid())
  name               String
  basePrice          Decimal               @db.Decimal(10, 2)
  durationMinutes    Int?
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  appointments       Appointment[]
  consumptions       ServiceConsumption[]
  packageItems       PackageTemplateItem[]
  packageUsages      ClientPackageUsage[]
  serviceEmployees   ServiceEmployee[]

  @@index([name])
  @@index([active])
}

model ServiceEmployee {
  id         String   @id @default(cuid())
  employeeId String
  serviceId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceId])
  @@index([employeeId])
  @@index([serviceId])
}

model Appointment {
  id         String            @id @default(cuid())
  clientId   String
  serviceId  String
  employeeId String
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service  Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  employee User    @relation("EmployeeAppointments", fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([startTime])
  @@index([endTime])
  @@index([status])
  @@index([employeeId])
  @@index([clientId])
  @@index([serviceId])
  @@index([startTime, employeeId])
}

model Product {
  id                   String          @id @default(cuid())
  name                 String
  sku                  String?         @unique
  sellingPrice         Decimal         @db.Decimal(10, 2)
  averagePurchasePrice Decimal         @default(0) @db.Decimal(10, 2)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  inventory            Inventory?
  stockMovements       StockMovement[]
  serviceConsumptions  ServiceConsumption[]

  @@index([name])
}

model Inventory {
  id                String   @id @default(cuid())
  productId         String   @unique
  currentStock      Int      @default(0)
  minimumStockLevel Int      @default(0)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([currentStock])
  @@index([minimumStockLevel])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]

  @@index([name])
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  supplierId    String?
  quantity      Int
  purchasePrice Decimal?          @db.Decimal(10, 2)
  type          StockMovementType
  createdAt     DateTime          @default(now())

  product  Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([supplierId])
  @@index([type])
  @@index([createdAt])
}

model ServiceConsumption {
  id           String   @id @default(cuid())
  serviceId    String
  productId    String
  quantityUsed Decimal  @db.Decimal(10, 3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([serviceId, productId])
  @@index([serviceId])
  @@index([productId])
}

model PackageTemplate {
  id          String                @id @default(cuid())
  name        String
  description String?
  totalPrice  Decimal               @db.Decimal(10, 2)
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  items       PackageTemplateItem[]
  purchases   ClientPackage[]

  @@index([name])
  @@index([active])
}

model PackageTemplateItem {
  id                String          @id @default(cuid())
  packageTemplateId String
  serviceId         String
  quantity          Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  packageTemplate PackageTemplate @relation(fields: [packageTemplateId], references: [id], onDelete: Cascade)
  service         Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([packageTemplateId])
  @@index([serviceId])
}

model ClientPackage {
  id                String              @id @default(cuid())
  clientId          String
  packageTemplateId String
  customPrice       Decimal?            @db.Decimal(10, 2)
  purchaseDate      DateTime
  totalSessions     Int
  remainingSessions Int
  expirationDate    DateTime?
  status            ClientPackageStatus @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  client          Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  packageTemplate PackageTemplate      @relation(fields: [packageTemplateId], references: [id], onDelete: Restrict)
  usages          ClientPackageUsage[]

  @@index([clientId])
  @@index([packageTemplateId])
  @@index([status])
  @@index([expirationDate])
}

model ClientPackageUsage {
  id              String   @id @default(cuid())
  clientPackageId String
  serviceId       String
  staffId         String
  datePerformed   DateTime
  notes           String?
  createdAt       DateTime @default(now())

  clientPackage ClientPackage @relation(fields: [clientPackageId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff         Staff         @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([clientPackageId])
  @@index([serviceId])
  @@index([staffId])
  @@index([datePerformed])
}

model Sale {
  id            String        @id @default(cuid())
  totalAmount   Decimal       @db.Decimal(10, 2)
  externalAmount Decimal      @default(0) @db.Decimal(10, 2)
  salonAmount   Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  staffId       String
  createdAt     DateTime      @default(now())

  staff Staff      @relation(fields: [staffId], references: [id], onDelete: Restrict)
  items SaleItem[]

  @@index([staffId])
  @@index([createdAt])
}

model SaleItem {
  id          String       @id @default(cuid())
  saleId      String
  type        SaleItemType
  referenceId String
  quantity    Int
  unitPrice   Decimal      @db.Decimal(10, 2)
  total       Decimal      @db.Decimal(10, 2)
  createdAt   DateTime     @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([type])
  @@index([referenceId])
}

model Expense {
  id        String          @id @default(cuid())
  category  ExpenseCategory
  amount    Decimal         @db.Decimal(10, 2)
  date      DateTime
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([date])
  @@index([category])
}
